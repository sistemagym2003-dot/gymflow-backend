# Base de datos (Supabase Postgres)
# Desde Supabase: Project Settings → Database → Connection string (URI, mode Session o Transaction)
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT: clave secreta para firmar y verificar tokens (mín. 32 caracteres)
JWT_SECRET=your-super-secret-key-at-least-32-chars

# Origen permitido para CORS (frontend en Vercel). En desarrollo usar http://localhost:3000
FRONTEND_URL=http://localhost:3000
